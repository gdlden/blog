# Blog Service Environment Variables
# Copy this file to .env and modify values for your deployment

# Database Configuration
# Full DSN format (overrides config.yaml when set)
# Format: host=HOST user=USER password=PASSWORD dbname=DB port=PORT sslmode=MODE
DATA_DATABASE_SOURCE="host=localhost user=postgres password=postgres dbname=postgres port=5432 sslmode=disable TimeZone=Asia/Shanghai"

# Alternative for cloud providers using postgres:// URL format:
# Note: GORM postgres driver accepts DSN format directly. URL format may require conversion.
# DATA_DATABASE_SOURCE="postgres://user:password@host:port/dbname?sslmode=require"

# How it works:
# - DATA_DATABASE_SOURCE maps to conf.Data.Database.Source via Kratos env source
# - Environment variables take precedence over config.yaml values
# - If DATA_DATABASE_SOURCE is not set, falls back to config.yaml
